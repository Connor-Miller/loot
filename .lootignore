target/
test-repos/
.claude/
.scratch/
# Site (loot.millerbyte.com, #257) deps + build output + Vercel CLI link.
site/node_modules/
site/.output/
site/.tanstack/
site/.nitro/
site/dist/
site/.vercel/
site/*.tsbuildinfo
.vercel/
# TS SDK (#423): npm deps + the wasm-pack-generated core (rebuilt from
# crates/loot-wasm), neither of which belongs in loot history.
sdk/node_modules/
sdk/wasm/
sdk/*.tsbuildinfo
